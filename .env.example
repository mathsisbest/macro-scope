# Copy this file to `.env` and fill in your free API keys.
# NEVER commit the real .env (it is gitignored). In CI/Streamlit, set these as secrets.

# --- Storage ---
# Local DuckDB file (dev / CI / offline demo). Always a local path — never an `md:` URL.
MMI_DUCKDB_PATH=data/mmi.duckdb

# --- MotherDuck (deployed / scheduled shared store; leave BLANK for local-only dev) ---
# Free "Lite" tier. Create a token in the MotherDuck UI -> Settings -> Access Tokens.
# When BOTH are set, the scheduled cron + dashboard target MotherDuck instead of the local file.
# In CI/Streamlit/GitHub Actions, set MOTHERDUCK_TOKEN as a secret (never commit it).
MMI_MOTHERDUCK_DATABASE=
MOTHERDUCK_TOKEN=

# --- Data source keys (all free) ---
# FRED (macro): https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=
# CoinGecko Demo (crypto): https://www.coingecko.com/en/api  -> Developer Dashboard
COINGECKO_API_KEY=
# The Odds API (OPTIONAL sports module): https://the-odds-api.com/
ODDS_API_KEY=

# --- GenAI layer (provider-agnostic) ---
# One of: gemini | groq | claude   (default: gemini — free tier)
LLM_PROVIDER=gemini
# Google AI Studio (free): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Groq (free): https://console.groq.com/keys
GROQ_API_KEY=
# Anthropic Claude (OPTIONAL, metered — not free): https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Gemini "thinking" effort for the brief: low | medium | high (default: medium).
# Higher = better reasoning, more free-tier token quota used. gemini provider only.
GEMINI_THINKING_LEVEL=medium

# --- Behaviour ---
MMI_LOG_LEVEL=INFO
